# =============================================================================
# PodPilot — Environment Variable Overrides
# =============================================================================
# Defaults live in src/PodPilot.Api/appsettings.json.
# Copy to `.env` only for values you need to override locally.
#
# ASP.NET Core: double-underscore (__) maps to nested config (e.g. Jwt__Secret → Jwt:Secret)
# =============================================================================

# Database — override if your MySQL credentials differ from defaults
ConnectionStrings__DefaultConnection=Server=localhost;Port=3306;Database=podpilot;User=podpilot;Password=podpilot_secret;

# JWT — change in production
Jwt__Secret=PodPilot_Super_Secret_Key_For_JWT_Token_Generation_2026!

# CORS — frontend origins (index from 0)
Cors__AllowedOrigins__0=http://localhost:5173
Cors__AllowedOrigins__1=http://localhost:3000

# Swagger — set to true to enable outside Development
Swagger__Enabled=true
