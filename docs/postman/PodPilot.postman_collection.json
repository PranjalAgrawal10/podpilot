{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "PodPilot",
    "description": "Basic PodPilot collection: auth, pods, gateway",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "accessToken", "value": "" },
    { "key": "gatewayApiKey", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"you@example.com\",\n  \"password\": \"password\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login"
          }
        },
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/health"
          }
        }
      ]
    },
    {
      "name": "Pods",
      "item": [
        {
          "name": "List pods",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/pods"
          }
        },
        {
          "name": "Create pod",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"providerId\": \"00000000-0000-0000-0000-000000000000\",\n  \"name\": \"demo-pod\",\n  \"gpuId\": \"NVIDIA_A100\",\n  \"gpuType\": \"A100\",\n  \"region\": \"US-OR-1\",\n  \"imageName\": \"ollama/ollama\",\n  \"gpuCount\": 1,\n  \"containerDiskGb\": 50,\n  \"volumeDiskGb\": 20\n}"
            },
            "url": "{{baseUrl}}/api/v1/pods"
          }
        }
      ]
    },
    {
      "name": "Gateway",
      "item": [
        {
          "name": "Gateway stats",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/gateway/stats"
          }
        },
        {
          "name": "List gateway API keys",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/gateway/api-keys"
          }
        },
        {
          "name": "Chat completions (inference)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{gatewayApiKey}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"llama3:latest\",\n  \"messages\": [{ \"role\": \"user\", \"content\": \"Hello from PodPilot\" }]\n}"
            },
            "url": "{{baseUrl}}/v1/chat/completions"
          }
        }
      ]
    }
  ]
}
